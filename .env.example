# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_TELEGRAM_USERNAME=your_telegram_username
ADMIN_TELEGRAM_ID=0  # your numeric Telegram ID — message @userinfobot to get it

# MySQL Database
DB_HOST=your_mysql_host
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# Storage (local path inside container)
GENERATED_PDF_DIR=/app/data/generated

# Optional: AWS S3 — fill all four to enable S3 upload, leave empty for local disk
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_S3_BUCKET=your_bucket_name
AWS_REGION=eu-north-1
